<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # CRITICAL: Pass Authorization header to PHP (Apache strips it by default)
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
  
  # Roteamento para a API PHP
  RewriteRule ^api/(.*)$ api.php [QSA,L]

  # Se o arquivo ou diretório existir, sirva-o (para assets, css, js)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Tudo que não for arquivo físico ou API vai para o index.html (React Router)
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Fallback: also try CGI passthrough for Authorization
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
