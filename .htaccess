<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # CRITICAL: Pass Authorization header to PHP (Apache strips it by default)
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # Se o arquivo físico existir, sirva direto (assets, css, js)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Roteamento para a API PHP — DEVE vir antes do fallback React
  RewriteRule ^api/(.*)$ api.php [QSA,L]

  # Tudo que não for arquivo físico ou API → React Router (index.html)
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Fallback: also pass Authorization via SetEnvIf
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
